
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
 
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  DOCTOR
  STAFF
}
enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}


model Tenant {
  id            String   @id @default(uuid()) 
  name          String
  slug          String   @unique
  createdAt     DateTime @default(now())
  users         User[]
  product       Product[]
  staff         Staff[]
  appointment   Appointment[]
  sale          Sale[]
} 

model User {
  id            String   @id @default(uuid()) 
  email         String   @unique
  password      String
  role          Role     @default(TENANT_ADMIN)
  profileImage  String?

  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id]) 

  createdAt DateTime @default(now())
}

model Customer {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  email         String
  phone         String
  appointment   Appointment[]

  createdAt  DateTime @default(now()) 
  updatedAt  DateTime @updatedAt

  sale          Sale[]
}

model Staff {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  email      String    @unique
  phone      String
  expertise  String
  workDays   String[]
  isActive   Boolean   @default(true)
  imageUrl   String?
  bio        String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  appointment   Appointment[]
}

model Product {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  category   String
  price      Decimal  @default(0.0)
  stock      Int       @default(0)

  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  sale          Sale[]
}

model Appointment {
  id              String   @id @default(uuid())

  startTime       DateTime  
  endTime         DateTime

  price           Decimal  @default(0.0)
  status          AppointmentStatus    @default(PENDING)
  notes           String?


  customerId      String
  customer        Customer             @relation(fields: [customerId], references: [id])

  staffId         String
  staff           Staff                @relation(fields: [staffId], references: [id])

  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id])

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Sale {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  
 
  quantity    Int      @default(1)
  totalPrice  Float    
 
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  createdAt   DateTime @default(now())

  @@index([tenantId]) // performans için, binlerce satıl oldupunda sadece tenantId ye ait olanalrı geitirr.
}