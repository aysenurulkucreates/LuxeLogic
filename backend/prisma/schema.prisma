
generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
 
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  DOCTOR
  STAFF
}

// Bu tablo, sistemi kiralayan klinikleri (kiracıları) temsil eder.
model Tenant {
  id        String   @id @default(uuid()) 
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  users     User[]
  product   Product[]
  staff     Staff[]
}

// Sistemdeki her bir birey burada tutulur.
model User {
  id            String   @id @default(uuid()) 
  email         String   @unique
  password      String
  role          Role     @default(TENANT_ADMIN)
  profileImage  String?

  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id]) 

  createdAt DateTime @default(now())
}

model Customer {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  email      String
  phone      String
}

model Staff {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  email      String    @unique
  phone      String
  expertise  String
  workDays   String[]
  isActive   Boolean   @default(true)
  imageUrl   String?
  bio        String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Product {
  id         String   @id @default(uuid())
  tenantId   String
  name       String
  category   String
  price      Float
  stock      Int      @default(0)

  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
